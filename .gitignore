# =====================================================
# SECRETS — never commit, never template, never suggest
# =====================================================
.env
.env.*
*.env
env.local
*.env.local
# Tracked template is safe — contains only placeholders, no real secrets.
!.env.example
secrets/
secrets.*
*.secret
*.secrets

# Credential files
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.ppk
.ssh/
credentials.json
credentials.*
service-account*.json

# Config files that commonly hold secrets
config.local.*
*.local.toml
*.local.yml
*.local.yaml
*.local.json
wrangler.toml
wrangler.*.toml

# =====================================================
# Dependencies
# =====================================================
node_modules/
.pnpm-store/
jspm_packages/

# =====================================================
# Build artifacts
# =====================================================
dist/
build/
out/
*.tsbuildinfo

# =====================================================
# Data volumes (Docker, SurrealDB)
# =====================================================
data/
surrealdb-data/
*.db
*.sqlite
*.sqlite3

# =====================================================
# Logs
# =====================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =====================================================
# Testing & Coverage
# =====================================================
coverage/
.nyc_output/
.vitest/

# Playwright MCP + screenshot artifacts (responsive verification,
# ad-hoc page captures during development). Screenshots should live
# in the knowledge graph or the issue tracker, not in git.
.playwright-mcp/
playwright-report/
test-results/
*-screenshot.png
login-*.png
share-*.png

# =====================================================
# OS
# =====================================================
.DS_Store
Thumbs.db
desktop.ini

# =====================================================
# Editors & IDEs
# =====================================================
.vscode/
.idea/
*.swp
*.swo
*.swn
.project
.settings/

# =====================================================
# Misc
# =====================================================
.cache/
.tmp/
tmp/
*.bak
*.backup

# =====================================================
# Marketing source docs
# =====================================================
# Marketing material lives canonically in plexus as kind=document
# entities (see entities:*). The .docx files are the editing
# source and should not be committed — they're kept on disk as
# working copies for Word/Pages round-tripping.
plexus-feature-uebersicht.docx
plexus-pitch-onepager.docx
*.pdf.tmp

# =====================================================
# Internal planning docs (superpowers specs & plans)
# =====================================================
# Brainstorming specs and implementation plans live under docs/
# as working artefacts — the canonical record of architectural
# decisions lives in plexus as kind=decision / kind=document.
# Keep them on disk for the current session, do not commit.
docs/*
# Exception: published screenshots for the README.
!docs/screenshots/
