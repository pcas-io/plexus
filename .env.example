# plexus (_graph) — environment configuration
#
# Copy to .env and fill in the required values.
# Never commit a real .env file — it is listed in .gitignore.

# --- HTTP ---
PLEXUS_PORT=8787
PLEXUS_BASE_URL=http://localhost:8787
PLEXUS_LOG_LEVEL=info

# --- Secrets (REQUIRED) ---
# Generate with:   openssl rand -hex 32
PLEXUS_ADMIN_TOKEN=replace-with-32-byte-hex
PLEXUS_OAUTH_SECRET=replace-with-32-byte-hex
PLEXUS_COOKIE_SECRET=replace-with-32-byte-hex

# --- SurrealDB (REQUIRED) ---
PLEXUS_SURREAL_URL=http://surrealdb:8000
PLEXUS_SURREAL_USER=root
PLEXUS_SURREAL_PASS=replace-with-strong-password
PLEXUS_SURREAL_NS=plexus
PLEXUS_SURREAL_DB=main

# --- WebAuthn / Passkeys ---
# PLEXUS_RP_ID must match the hostname (no scheme, no port) you serve the dashboard on.
# For localhost development, leave as "localhost". For production, set to your domain.
PLEXUS_RP_ID=localhost
PLEXUS_RP_NAME=plexus
